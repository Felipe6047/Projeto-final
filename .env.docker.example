# Copie para .env na raiz do projeto (opcional) para customizar o Docker Compose:
#   cp .env.docker.example .env

MYSQL_ROOT_PASSWORD=frik_root
MYSQL_DATABASE=frik
MYSQL_USER=frik
MYSQL_PASSWORD=frik_pass
MYSQL_PORT=3306

BACKEND_PORT=3333
FRONTEND_PORT=3000

# URL usada pelo navegador para chamar a API (deve apontar para o host, não para o nome do serviço Docker)
NEXT_PUBLIC_API_URL=http://localhost:3333/api

JWT_SECRET=frik-docker-jwt-secret-change-in-production
